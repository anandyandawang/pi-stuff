{
  "arch": "aarch64",
  "distro": "alpine",
  "env": {
    "JAVA_HOME": "/usr/lib/jvm/java-21-openjdk",
    "GRADLE_OPTS": "-Dorg.gradle.daemon=false"
  },
  "alpine": {
    "version": "3.23.0",
    "kernelPackage": "linux-virt",
    "rootfsPackages": [
      "linux-virt",
      "rng-tools",
      "bash",
      "ca-certificates",
      "curl",
      "e2fsprogs",
      "openssh",
      "git",
      "git-lfs",
      "github-cli",
      "openjdk21",
      "openjdk17",
      "gradle",
      "maven",
      "nodejs",
      "npm",
      "fzf",
      "jq",
      "vim",
      "nano",
      "coreutils",
      "findutils",
      "grep",
      "file"
    ]
  },
  "rootfs": {
    "sizeMb": 16384
  },
  "runtimeDefaults": {
    "rootfsMode": "cow"
  }
}
